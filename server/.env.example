# Server environment variables — copy this to server/.env for local development
# On Render, set these in the Web Service → Environment tab

# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/community-finder?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ── CORS (local dev only — not needed in production) ─────────────────────────
# CLIENT_ORIGIN=http://localhost:5173
