# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output (Render builds this at deploy time — don't commit it) ────────
dist/
client/dist/
server/dist/

# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.production
client/.env
client/.env.local
server/.env
server/.env.local
# .env.example files ARE intentionally committed (they have no real secrets)
!server/.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.out.log
*.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
